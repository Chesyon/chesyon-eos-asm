<PMD2>
  <!--=======================================================================-->
  <!--ASM Patches Constants-->
  <!--=======================================================================-->
  <!--Put the data defining your patch here.-->
  <ASMPatchesConstants>

    <!--*******************-->
    <!--Patches list-->
    <!--*******************-->
    <!--Patching steps for applying various asm patches on the game-->
    <Patches>
      <Game id="EoS_NA" id2="EoS_EU">
        <Patch id="SwapLeaderPosition">
	      <OpenBin filepath="overlay/overlay_0029.bin">
            <Include filename ="patch_ov29.asm"/>
          </OpenBin>
	      <OpenBin filepath="overlay/overlay_0036.bin">
            <Include filename ="patch_ov36.asm"/>
          </OpenBin>
          <Parameters>
            <Param name="SwapStringId" label="String ID to show when swapping" min="0" max="65535" default="2613" type="int"/>
            <Param name="ReplaceString" label="Replace string with default text" type="select">
              <Option label="Yes" type="int">1</Option>
              <Option label="No" type="int">0</Option>
            </Param>
          </Parameters>
        </Patch>
      </Game>
      <Game id="EoS_JP">
        <Patch id="SwapLeaderPosition">
	      <OpenBin filepath="overlay/overlay_0029.bin">
            <Include filename ="patch_ov29.asm"/>
          </OpenBin>
	      <OpenBin filepath="overlay/overlay_0036.bin">
            <Include filename ="patch_ov36.asm"/>
          </OpenBin>
          <Parameters>
            <Param name="SwapStringId" label="String ID to show when swapping" min="0" max="65535" default="4874" type="int"/>
            <Param name="ReplaceString" label="Replace string with default text" type="select">
              <Option label="Yes" type="int">1</Option>
              <Option label="No" type="int">0</Option>
            </Param>
          </Parameters>
        </Patch>
      </Game>
    </Patches>
  </ASMPatchesConstants>
</PMD2>

